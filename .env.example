# Waitlist storage — Resend (https://resend.com).
# When BOTH are set, POST /api/waitlist adds each signup to a Resend Audience.
# When either is missing, signups are appended to .data/waitlist.jsonl (dev only).
#
#   1. Create a free account → API Keys → copy a key into RESEND_API_KEY.
#   2. Audiences → create/choose one → copy its ID into RESEND_AUDIENCE_ID.
#   3. Put real values in .env.local (gitignored), then restart `next dev`.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Launch switch — the App Store link (e.g. https://apps.apple.com/app/id…).
# When set, every CTA site-wide flips from waitlist capture to a "Download"
# link. Leave unset until the app is approved; set it in Vercel and redeploy
# to launch (NEXT_PUBLIC_ vars are inlined at build time).
NEXT_PUBLIC_APPSTORE_URL=
